nextflow_pipeline {

    name "Test Workflow main.nf"
    script "main.nf"

    tag "pipeline"
    tag "pipeline_default"

    options "-stub"

    test("pipeline_default - default") {

        when {
            params {
                outdir = "${outputDir}"
            }
        }

        then {
            assertAll(
                { assert workflow.success },
                { assert snapshot(
                    path("${outputDir}")
                        .list()
                        .collect { Utils.getRecursiveFileNames(it, "${outputDir}") }
                        .flatten()
                        .findAll {
                            !(it.contains("/execution_") || it.contains("/params_") || it.contains("/pipeline_"))
                        }
                        .collect {
                            it.replace(Utils.getDynamicOutputName(), "<version>_<date>")
                        }
                ).match() }
            )
        }

    }

    test("pipeline_default - default one sample") {

        when {
            params {
                outdir = "${outputDir}"
                input = "${projectDir}/tests/inputs/samplesheet_one.csv"
                ped = null
            }
        }

        then {
            assertAll(
                { assert workflow.success },
                { assert snapshot(
                    path("${outputDir}")
                        .list()
                        .collect { Utils.getRecursiveFileNames(it, "${outputDir}") }
                        .flatten()
                        .findAll {
                            !(it.contains("/execution_") || it.contains("/params_") || it.contains("/pipeline_"))
                        }
                        .collect {
                            it.replace(Utils.getDynamicOutputName(), "<version>_<date>")
                        }
                ).match() }
            )
        }

    }

}
