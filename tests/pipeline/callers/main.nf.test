nextflow_pipeline {

    name "Test Workflow main.nf"
    script "main.nf"

    tag "pipeline"
    tag "pipeline_callers"

    options "-stub"

    test("pipeline_callers - vardict") {

        when {
            params {
                outdir = "${outputDir}"
                callers = "vardict"
            }
        }

        then {
            assertAll(
                { assert workflow.success },
                { assert snapshot(
                    path("${outputDir}")
                        .list()
                        .collect { Utils.getRecursiveFileNames(it, "${outputDir}") }
                        .flatten()
                        .findAll {
                            !(it.contains("/execution_") || it.contains("/params_") || it.contains("/pipeline_"))
                        }
                        .collect {
                            it.replace(Utils.getDynamicOutputName(), "<version>_<date>")
                        }
                ).match() }
            )
        }

    }

    test("pipeline_callers - haplotypecaller") {

        when {
            params {
                outdir = "${outputDir}"
                callers = "haplotypecaller"
            }
        }

        then {
            assertAll(
                { assert workflow.success },
                { assert snapshot(
                    path("${outputDir}")
                        .list()
                        .collect { Utils.getRecursiveFileNames(it, "${outputDir}") }
                        .flatten()
                        .findAll {
                            !(it.contains("/execution_") || it.contains("/params_") || it.contains("/pipeline_"))
                        }
                        .collect {
                            it.replace(Utils.getDynamicOutputName(), "<version>_<date>")
                        }
                ).match() }
            )
        }

    }

    test("pipeline_callers - vardict + haplotypecaller") {

        when {
            params {
                outdir = "${outputDir}"
                callers = "haplotypecaller,vardict"
            }
        }

        then {
            assertAll(
                { assert workflow.success },
                { assert snapshot(
                    path("${outputDir}")
                        .list()
                        .collect { Utils.getRecursiveFileNames(it, "${outputDir}") }
                        .flatten()
                        .findAll {
                            !(it.contains("/execution_") || it.contains("/params_") || it.contains("/pipeline_"))
                        }
                        .collect {
                            it.replace(Utils.getDynamicOutputName(), "<version>_<date>")
                        }
                ).match() }
            )
        }

    }

}
