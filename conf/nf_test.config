/*
========================================================================================
    Nextflow config file for running tests
========================================================================================
*/

params {

    // Input data
    input           = "${baseDir}/tests/inputs/samplesheet.csv"

    // Genome references
    igenomes_ignore = true
    genome          = 'GRCh38'
    genomes        = [:]

    // Required params
    scatter_count   = 2
    project         = "test"
    skip_date_project = true

}

process {
    // Limit resources so that this can run on GitHub Actions
    resourceLimits = [
        cpus  : 2,
        memory: 6.GB,
        time  : 6.h
    ]
}
